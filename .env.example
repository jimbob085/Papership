# Server
PORT=3100
NODE_ENV=development

# Paperclip
PAPERCLIP_BASE_URL=https://your-paperclip-instance.example.com
PAPERCLIP_API_KEY=pk_your_paperclip_api_key

# PermaShip
PERMASHIP_BASE_URL=https://control.permaship.ai/api
PERMASHIP_API_KEY=cc_your_permaship_api_key
PERMASHIP_ORG_ID=org_example
PERMASHIP_PROJECT_ID=proj_example
PERMASHIP_REPO_KEY=my-org/my-repo
PERMASHIP_WEBHOOK_SECRET=whsec_your_webhook_secret

# Defaults
DEFAULT_TICKET_KIND=feature
DEFAULT_TICKET_PRIORITY=2
